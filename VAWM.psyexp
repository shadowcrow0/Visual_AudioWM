      </RoutineSettingsComponent>
    </Routine>
    <Routine name="studyindtruc">
      <RoutineSettingsComponent name="studyindtruc" plugin="None">
        <Param val="none" valType="str" updates="None" name="backgroundFit"/>
        <Param val="" valType="str" updates="None" name="backgroundImg"/>
        <Param val="$[0,0,0]" valType="color" updates="None" name="color"/>
        <Param val="rgb" valType="str" updates="None" name="colorSpace"/>
        <Param val="" valType="str" updates="constant" name="desc"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="" valType="code" updates="None" name="durationEstim"/>
        <Param val="False" valType="code" updates="None" name="forceNonSlip"/>
        <Param val="studyindtruc" valType="code" updates="None" name="name"/>
        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
    </Routine>
    <Routine name="study_stage">
      <RoutineSettingsComponent name="study_stage" plugin="None">
        <Param val="none" valType="str" updates="None" name="backgroundFit"/>
        <Param val="" valType="str" updates="None" name="backgroundImg"/>
        <Param val="$[0,0,0]" valType="color" updates="None" name="color"/>
        <Param val="rgb" valType="str" updates="None" name="colorSpace"/>
        <Param val="" valType="str" updates="constant" name="desc"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="" valType="code" updates="None" name="durationEstim"/>
        <Param val="False" valType="code" updates="None" name="forceNonSlip"/>
        <Param val="study_stage" valType="code" updates="None" name="name"/>
        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
      <CodeComponent name="StudyCode" plugin="None">
        <Param val="import numpy as np&amp;#10;import random&amp;#10;import warnings&amp;#10;from skimage import color as skcolor&amp;#10;&amp;#10;warnings.filterwarnings('ignore')&amp;#10;&amp;#10;# ------------------------------------------------------------&amp;#10;# Color category hue ranges (CIELAB H angle in degrees)&amp;#10;# ------------------------------------------------------------&amp;#10;&amp;#10;CATEGORIES = {&amp;#10;    'red':    (330, 390),&amp;#10;    'orange': (30,  75),&amp;#10;    'yellow': (75,  105),&amp;#10;    'green':  (105, 180),&amp;#10;    'blue':   (180, 270),&amp;#10;    'purple': (270, 330),&amp;#10;}&amp;#10;&amp;#10;# ------------------------------------------------------------&amp;#10;# Helper functions&amp;#10;# ------------------------------------------------------------&amp;#10;&amp;#10;def delta_e(c1, c2):&amp;#10;    return float(np.sqrt(np.sum((np.array(c1) - np.array(c2)) ** 2)))&amp;#10;&amp;#10;def is_in_gamut(L, a, b):&amp;#10;    rgb = skcolor.lab2rgb(np.array([[[L, a, b]]]))[0][0]&amp;#10;    return bool(np.all(rgb &gt;= 0) and np.all(rgb &lt;= 1))&amp;#10;&amp;#10;def is_valid_color(lab):&amp;#10;    L, a, b = lab&amp;#10;    C = np.sqrt(a**2 + b**2)&amp;#10;    return is_in_gamut(L, a, b) and 35 &lt; L &lt; 75 and C &gt; 35&amp;#10;&amp;#10;def get_category(lab):&amp;#10;    L, a, b = lab&amp;#10;    H = np.degrees(np.arctan2(b, a)) % 360&amp;#10;    for name, (h_min, h_max) in CATEGORIES.items():&amp;#10;        h_max_wrapped = h_max % 360&amp;#10;        if h_min &gt; h_max_wrapped:&amp;#10;            if H &gt;= h_min or H &lt; h_max_wrapped:&amp;#10;                return name&amp;#10;        else:&amp;#10;            if h_min &lt;= H &lt; h_max_wrapped:&amp;#10;                return name&amp;#10;    return None&amp;#10;&amp;#10;def lab_to_hex(lab):&amp;#10;    L, a, b = lab&amp;#10;    rgb = skcolor.lab2rgb(np.array([[[L, a, b]]]))[0][0]&amp;#10;    r, g, b_ch = [int(x * 255) for x in np.clip(rgb, 0, 1)]&amp;#10;    return '#{:02X}{:02X}{:02X}'.format(r, g, b_ch)&amp;#10;&amp;#10;def random_lab_in_category(category):&amp;#10;    h_min, h_max = CATEGORIES[category]&amp;#10;    for _ in range(500):&amp;#10;        L     = np.random.uniform(35, 75)&amp;#10;        C     = np.random.uniform(35, 60)&amp;#10;        H_deg = np.random.uniform(h_min, h_max) % 360&amp;#10;        H_rad = H_deg * np.pi / 180&amp;#10;        lab   = np.array([L, C * np.cos(H_rad), C * np.sin(H_rad)])&amp;#10;        if is_valid_color(lab):&amp;#10;            return lab&amp;#10;    return None&amp;#10;&amp;#10;def find_color(target, de_min, de_max, max_tries=3000):&amp;#10;    for _ in range(max_tries):&amp;#10;        direction = np.random.randn(3)&amp;#10;        direction = direction / np.linalg.norm(direction)&amp;#10;        candidate = target + direction * np.random.uniform(de_min, de_max)&amp;#10;        if is_valid_color(candidate) and de_min &lt; delta_e(target, candidate) &lt; de_max:&amp;#10;            if get_category(candidate) is not None:&amp;#10;                return candidate&amp;#10;    return None&amp;#10;&amp;#10;# ------------------------------------------------------------&amp;#10;# Generate color pool (24 entries × 6 colors each)&amp;#10;# ------------------------------------------------------------&amp;#10;&amp;#10;color_pool = []&amp;#10;all_targets = []&amp;#10;category_names = list(CATEGORIES.keys())&amp;#10;&amp;#10;while len(color_pool) &lt; 24:&amp;#10;    cat1, cat2 = np.random.choice(category_names, size=2, replace=False)&amp;#10;&amp;#10;    t1 = random_lab_in_category(cat1)&amp;#10;    if t1 is None:&amp;#10;        continue&amp;#10;&amp;#10;    t2 = None&amp;#10;    for _ in range(200):&amp;#10;        candidate = random_lab_in_category(cat2)&amp;#10;        if candidate is not None and delta_e(t1, candidate) &gt; 25:&amp;#10;            t2 = candidate&amp;#10;            break&amp;#10;    if t2 is None:&amp;#10;        continue&amp;#10;&amp;#10;    if any(delta_e(t1, prev) &lt; 15 or delta_e(t2, prev) &lt; 15 for prev in all_targets):&amp;#10;        continue&amp;#10;&amp;#10;    h1 = find_color(t1, 15, 80)&amp;#10;    if h1 is None:&amp;#10;        continue&amp;#10;    l1 = find_color(t1, 2, 10)&amp;#10;    if l1 is None:&amp;#10;        continue&amp;#10;    h2 = find_color(t2, 15, 80)&amp;#10;    if h2 is None:&amp;#10;        continue&amp;#10;    l2 = find_color(t2, 2, 10)&amp;#10;    if l2 is None:&amp;#10;        continue&amp;#10;&amp;#10;    color_pool.append({&amp;#10;        'target1': lab_to_hex(t1), 'high1': lab_to_hex(h1), 'low1': lab_to_hex(l1),&amp;#10;        'target2': lab_to_hex(t2), 'high2': lab_to_hex(h2), 'low2': lab_to_hex(l2),&amp;#10;    })&amp;#10;    all_targets.extend([t1, t2])&amp;#10;    print(f&quot;Entry {len(color_pool):2d}/24  &quot;&amp;#10;          f&quot;T1={lab_to_hex(t1)} H1={lab_to_hex(h1)} L1={lab_to_hex(l1)}  &quot;&amp;#10;          f&quot;T2={lab_to_hex(t2)} H2={lab_to_hex(h2)} L2={lab_to_hex(l2)}&quot;)&amp;#10;&amp;#10;print(&quot;Color pool ready.&quot;)" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="/* Syntax Error: Fix Python code */" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="my_color_list = []&amp;#10;my_audio_list = []&amp;#10;my_posx_list = []&amp;#10;my_posy_list = []" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="my_color_list = [];&amp;#10;my_audio_list = [];&amp;#10;my_posx_list = [];&amp;#10;my_posy_list = [];&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="condition = Math.random.choice([0, 1, 2, 3]);&amp;#10;fix = 0.3;&amp;#10;StimTime1 = fix;&amp;#10;if ((condition === 0)) {&amp;#10;    targetV = 1;&amp;#10;    targetA = 1;&amp;#10;    StimDur1 = 1;&amp;#10;    StimTime2 = 0;&amp;#10;    StimDur2 = 0;&amp;#10;    StimTime3 = (StimTime1 + StimDur1);&amp;#10;    StimDur3 = 1;&amp;#10;    StimTime4 = 0;&amp;#10;    StimDur4 = 0;&amp;#10;} else {&amp;#10;    if ((condition === 1)) {&amp;#10;        targetV = 2;&amp;#10;        targetA = 1;&amp;#10;        StimDur1 = 1;&amp;#10;        StimTime2 = (StimTime1 + StimDur1);&amp;#10;        StimDur2 = 1;&amp;#10;        StimTime3 = (StimTime2 + StimDur2);&amp;#10;        StimDur3 = 1;&amp;#10;        StimTime4 = 0;&amp;#10;        StimDur4 = 0;&amp;#10;    } else {&amp;#10;        if ((condition === 2)) {&amp;#10;            targetV = 2;&amp;#10;            targetA = 2;&amp;#10;            StimDur1 = 1;&amp;#10;            StimTime2 = (StimTime1 + StimDur1);&amp;#10;            StimDur2 = 1;&amp;#10;            StimTime3 = (StimTime2 + StimDur2);&amp;#10;            StimDur3 = 1;&amp;#10;            StimTime4 = (StimTime3 + StimDur3);&amp;#10;            StimDur4 = 1;&amp;#10;        } else {&amp;#10;            if ((condition === 3)) {&amp;#10;                targetV = 1;&amp;#10;                targetA = 2;&amp;#10;                StimDur1 = 1;&amp;#10;                StimTime2 = 0;&amp;#10;                StimDur2 = 0;&amp;#10;                StimTime3 = (StimTime1 + StimDur1);&amp;#10;                StimDur3 = 1;&amp;#10;                StimTime4 = (StimTime3 + StimDur3);&amp;#10;                StimDur4 = 1;&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;entry = color_pool[study.thisN];&amp;#10;color1 = entry[&quot;target1&quot;];&amp;#10;opac1 = 1;&amp;#10;if ((targetV === 2)) {&amp;#10;    color2 = entry[&quot;target2&quot;];&amp;#10;    opac2 = 1;&amp;#10;} else {&amp;#10;    color2 = entry[&quot;target2&quot;];&amp;#10;    opac2 = 0;&amp;#10;}&amp;#10;posx1 = (- 0.2);&amp;#10;posy1 = 0.0;&amp;#10;posx2 = 0.2;&amp;#10;posy2 = 0.0;&amp;#10;dfp_conditions = [&quot;TL&quot;, &quot;TH&quot;, &quot;LT&quot;, &quot;LH&quot;, &quot;LL&quot;, &quot;HT&quot;, &quot;HL&quot;, &quot;HH&quot;];&amp;#10;probe_list = [];&amp;#10;if ((targetV === 1)) {&amp;#10;    for (var dfp, _pj_c = 0, _pj_a = dfp_conditions, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        dfp = _pj_a[_pj_c];&amp;#10;        probe_list.push({&quot;which&quot;: 1, &quot;dfp&quot;: dfp});&amp;#10;        probe_list.push({&quot;which&quot;: 1, &quot;dfp&quot;: dfp});&amp;#10;    }&amp;#10;} else {&amp;#10;    for (var dfp, _pj_c = 0, _pj_a = dfp_conditions, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        dfp = _pj_a[_pj_c];&amp;#10;        probe_list.push({&quot;which&quot;: 1, &quot;dfp&quot;: dfp});&amp;#10;    }&amp;#10;    for (var dfp, _pj_c = 0, _pj_a = dfp_conditions, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        dfp = _pj_a[_pj_c];&amp;#10;        probe_list.push({&quot;which&quot;: 2, &quot;dfp&quot;: dfp});&amp;#10;    }&amp;#10;}&amp;#10;Math.random.shuffle(probe_list);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# --- 1. 抽 condition ---&amp;#10;condition = random.choice([0, 1, 2, 3])&amp;#10;fix = .3&amp;#10;StimTime1 = fix&amp;#10;&amp;#10;if condition == 0:&amp;#10;    targetV = 1&amp;#10;    targetA = 1&amp;#10;    StimDur1 = 1&amp;#10;    StimTime2 = 0&amp;#10;    StimDur2 = 0&amp;#10;    StimTime3 = StimTime1 +StimDur1&amp;#10;    StimDur3 = 1&amp;#10;    StimTime4 = 0&amp;#10;    StimDur4 = 0&amp;#10;elif condition == 1:&amp;#10;    targetV = 2&amp;#10;    targetA = 1&amp;#10;    StimDur1 = 1&amp;#10;    StimTime2 = StimTime1 +StimDur1&amp;#10;    StimDur2 = 1&amp;#10;    StimTime3 = StimTime2 +StimDur2&amp;#10;    StimDur3 = 1&amp;#10;    StimTime4 = 0&amp;#10;    StimDur4 = 0&amp;#10;&amp;#10;elif condition == 2:&amp;#10;    targetV = 2&amp;#10;    targetA = 2&amp;#10;    StimDur1 = 1&amp;#10;    StimTime2 = StimTime1 +StimDur1&amp;#10;    StimDur2 = 1&amp;#10;    StimTime3 = StimTime2 +StimDur2&amp;#10;    StimDur3 = 1&amp;#10;    StimTime4 = StimTime3 +StimDur3&amp;#10;    StimDur4 = 1&amp;#10;&amp;#10;elif condition == 3:&amp;#10;    targetV = 1&amp;#10;    targetA = 2&amp;#10;    StimDur1 = 1&amp;#10;    StimTime2 = 0&amp;#10;    StimDur2 = 0&amp;#10;    StimTime3 = StimTime1 +StimDur1&amp;#10;    StimDur3 = 1&amp;#10;    StimTime4 = StimTime3 +StimDur3&amp;#10;    StimDur4 = 1&amp;#10;&amp;#10;# --- 2. 從 color_pool 取顏色 ---&amp;#10;entry = color_pool[study.thisN]&amp;#10;&amp;#10;color1 = entry['target1']&amp;#10;opac1 = 1&amp;#10;&amp;#10;if targetV == 2:&amp;#10;    color2 = entry['target2']&amp;#10;    opac2 = 1&amp;#10;else:&amp;#10;    color2 = entry['target2']  # 佔位，不顯示&amp;#10;    opac2 = 0&amp;#10;&amp;#10;# --- 3. 位置（先固定，之後改） ---&amp;#10;posx1 = -0.2&amp;#10;posy1 = 0.0&amp;#10;posx2 = 0.2&amp;#10;posy2 = 0.0&amp;#10;&amp;#10;# --- 4. 建立 probe list ---&amp;#10;dfp_conditions = ['TL', 'TH', 'LT', 'LH', 'LL', 'HT', 'HL', 'HH']&amp;#10;&amp;#10;probe_list = []&amp;#10;&amp;#10;if targetV == 1:&amp;#10;    for dfp in dfp_conditions:&amp;#10;        probe_list.append({'which': 1, 'dfp': dfp})&amp;#10;        probe_list.append({'which': 1, 'dfp': dfp})&amp;#10;else:&amp;#10;    for dfp in dfp_conditions:&amp;#10;        probe_list.append({'which': 1, 'dfp': dfp})&amp;#10;    for dfp in dfp_conditions:&amp;#10;        probe_list.append({'which': 2, 'dfp': dfp})&amp;#10;&amp;#10;random.shuffle(probe_list)" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="psychoJS.experiment.addData(&quot;study_condition&quot;, condition);&amp;#10;psychoJS.experiment.addData(&quot;study_targetV&quot;, targetV);&amp;#10;psychoJS.experiment.addData(&quot;study_targetA&quot;, targetA);&amp;#10;psychoJS.experiment.addData(&quot;study_entry_index&quot;, study.thisN);&amp;#10;psychoJS.experiment.addData(&quot;target1&quot;, entry[&quot;target1&quot;]);&amp;#10;psychoJS.experiment.addData(&quot;high1&quot;, entry[&quot;high1&quot;]);&amp;#10;psychoJS.experiment.addData(&quot;low1&quot;, entry[&quot;low1&quot;]);&amp;#10;psychoJS.experiment.addData(&quot;target2&quot;, entry[&quot;target2&quot;]);&amp;#10;psychoJS.experiment.addData(&quot;high2&quot;, entry[&quot;high2&quot;]);&amp;#10;psychoJS.experiment.addData(&quot;low2&quot;, entry[&quot;low2&quot;]);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="thisExp.addData('study_condition', condition)&amp;#10;thisExp.addData('study_targetV', targetV)&amp;#10;thisExp.addData('study_targetA', targetA)&amp;#10;thisExp.addData('study_entry_index', study.thisN)&amp;#10;thisExp.addData('target1', entry['target1'])&amp;#10;thisExp.addData('high1', entry['high1'])&amp;#10;thisExp.addData('low1', entry['low1'])&amp;#10;thisExp.addData('target2', entry['target2'])&amp;#10;thisExp.addData('high2', entry['high2'])&amp;#10;thisExp.addData('low2', entry['low2'])" valType="extendedCode" updates="constant" name="End Routine"/>
