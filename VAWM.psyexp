        <Param val="if (((condition === 0) &amp;&amp; (ResponseBox.keys === 4))) {&amp;#10;    resp = &quot;Correct&quot;;&amp;#10;} else {&amp;#10;    if (((condition === 1) &amp;&amp; (ResponseBox.keys === 4))) {&amp;#10;        resp = &quot;Correct&quot;;&amp;#10;    } else {&amp;#10;        if (((condition === 2) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;            resp = &quot;Correct&quot;;&amp;#10;        } else {&amp;#10;            if (((condition === 3) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                resp = &quot;Correct&quot;;&amp;#10;            } else {&amp;#10;                if (((condition === 4) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                    resp = &quot;Correct&quot;;&amp;#10;                } else {&amp;#10;                    if (((condition === 5) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                        resp = &quot;Correct&quot;;&amp;#10;                    } else {&amp;#10;                        if (((condition === 6) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                            resp = &quot;Correct&quot;;&amp;#10;                        } else {&amp;#10;                            if (((condition === 7) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                                resp = &quot;Correct&quot;;&amp;#10;                            } else {&amp;#10;                                if (((condition === 8) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                                    resp = &quot;Correct&quot;;&amp;#10;                                } else {&amp;#10;                                    if (((condition === 9) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                                        resp = &quot;Correct&quot;;&amp;#10;                                    } else {&amp;#10;                                        if (((condition === 10) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                                            resp = &quot;Correct&quot;;&amp;#10;                                        } else {&amp;#10;                                            if (((condition === 11) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                                                resp = &quot;Correct&quot;;&amp;#10;                                            } else {&amp;#10;                                                if (((condition === 12) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                                                    resp = &quot;Correct&quot;;&amp;#10;                                                } else {&amp;#10;                                                    if (((condition === 13) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                                                        resp = &quot;Correct&quot;;&amp;#10;                                                    } else {&amp;#10;                                                        if (((condition === 14) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                                                            resp = &quot;Correct&quot;;&amp;#10;                                                        } else {&amp;#10;                                                            if (((condition === 15) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                                                                resp = &quot;Correct&quot;;&amp;#10;                                                            } else {&amp;#10;                                                                if (((condition === 16) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                                                                    resp = &quot;Correct&quot;;&amp;#10;                                                                } else {&amp;#10;                                                                    if (((condition === 17) &amp;&amp; (ResponseBox.keys === 3))) {&amp;#10;                         