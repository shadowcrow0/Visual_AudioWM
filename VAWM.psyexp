        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if (((condition === 0) &amp;&amp; (key_resp.keys === &quot;y&quot;))) {&amp;#10;    resp = &quot;Correct&quot;;&amp;#10;} else {&amp;#10;    if (((condition === 1) &amp;&amp; (key_resp.keys === &quot;y&quot;))) {&amp;#10;        resp = &quot;Correct&quot;;&amp;#10;    } else {&amp;#10;        if (((condition === 2) &amp;&amp; (key_resp.keys === &quot;n&quot;))) {&amp;#10;            resp = &quot;Correct&quot;;&amp;#10;        } else {&amp;#10;            if (((condition === 3) &amp;&amp; (key_resp.keys === &quot;n&quot;))) {&amp;#10;                resp = &quot;Correct&quot;;&amp;#10;            } else {&amp;#10;                if (((condition === 4) &amp;&amp; (key_resp.keys === &quot;n&quot;))) {&amp;#10;                    resp = &quot;Correct&quot;;&amp;#10;                } else {&amp;#10;                    if (((condition === 5) &amp;&amp; (key_resp.keys === &quot;n&quot;))) {&amp;#10;                        resp = &quot;Correct&quot;;&amp;#10;                    } else {&amp;#10;                        if (((condition === 6) &amp;&amp; (key_resp.keys === &quot;n&quot;))) {&amp;#10;                            resp = &quot;Correct&quot;;&amp;#10;                        } else {&amp;#10;                            if (((condition === 7) &amp;&amp; (key_resp.keys === &quot;n&quot;))) {&amp;#10;                                resp = &quot;Correct&quot;;&amp;#10;                            } else {&amp;#10;                                if (((condition === 8) &amp;&amp; (key_resp.keys === &quot;n&quot;))) {&amp;#10;                                    resp = &quot;Correct&quot;;&amp;#10;                                } else {&amp;#10;                                    if (((condition === 9) &amp;&amp; (key_resp.keys === &quot;n&quot;))) {&amp;#10;                                        resp = &quot;Correct&quot;;&amp;#10;                                    } else {&amp;#10;                                        if (((condition === 10) &amp;&